(export (version "E")
  (design
    (source "gen_freezer_netlist_usb_flipped.py")
    (date "2026-06-16")
    (tool "gen_freezer_netlist_usb_flipped.py 1.0.0"))
  (components
    (comp (ref "BT1")
      (value "LS14250")
      (footprint "nice!nano clone:BAT_1011")
      (description "Saft Li-SOCl2 3.6V 1/2AA, polarity-keyed holder"))
    (comp (ref "C1")
      (value "100uF")
      (footprint "Capacitor_THT:CP_Radial_D8.0mm_P3.50mm")
      (description "Al-polymer radial THT, low-leakage low-ESR; size to actual part"))
    (comp (ref "C2")
      (value "10nF")
      (footprint "Capacitor_SMD:C_0805_2012Metric")
      (description "SAADC sampling reservoir at P0.02"))
    (comp (ref "J1")
      (value "DS18B20")
      (footprint "Connector_JST:JST_PH_B3B-PH-K_1x03_P2.00mm_Vertical")
      (description "Probe: 1=VDD 2=DATA 3=GND"))
    (comp (ref "J2")
      (value "SERIAL")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical")
      (description "Debug UART: 1=GND 2=VCC 3=TX 4=RX"))
    (comp (ref "JP1")
      (value "BATT")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical")
      (description "Cell isolation jumper - pull before USB"))
    (comp (ref "R1")
      (value "1M")
      (footprint "Resistor_SMD:R_0805_2012Metric")
      (description "Divider high side"))
    (comp (ref "R2")
      (value "1M")
      (footprint "Resistor_SMD:R_0805_2012Metric")
      (description "Divider low side"))
    (comp (ref "R3")
      (value "4.7k")
      (footprint "Resistor_SMD:R_0805_2012Metric")
      (description "OneWire pull-up to VBAT"))
    (comp (ref "U1")
      (value "nice!nano nRF52840")
      (footprint "nice!nano clone:nice_nano_teyleten_usb_flipped")
      (description "Teyleten clone, socketed; flipped USB-end orientation"))
  )
  (nets
    (net (code "1") (name "CELL+")
      (node (ref "BT1") (pin "P"))
      (node (ref "JP1") (pin "1"))
    )
    (net (code "2") (name "VBAT")
      (node (ref "JP1") (pin "2"))
      (node (ref "U1") (pin "B+"))
      (node (ref "C1") (pin "1"))
      (node (ref "R1") (pin "1"))
      (node (ref "R3") (pin "1"))
      (node (ref "J1") (pin "1"))
    )
    (net (code "3") (name "GND")
      (node (ref "BT1") (pin "N"))
      (node (ref "U1") (pin "GND"))
      (node (ref "U1") (pin "B-"))
      (node (ref "C1") (pin "2"))
      (node (ref "R2") (pin "2"))
      (node (ref "C2") (pin "2"))
      (node (ref "J1") (pin "3"))
      (node (ref "J2") (pin "1"))
    )
    (net (code "4") (name "DATA")
      (node (ref "U1") (pin "P0.24"))
      (node (ref "R3") (pin "2"))
      (node (ref "J1") (pin "2"))
    )
    (net (code "5") (name "SENSE")
      (node (ref "U1") (pin "P0.02"))
      (node (ref "R1") (pin "2"))
      (node (ref "R2") (pin "1"))
      (node (ref "C2") (pin "1"))
    )
    (net (code "6") (name "TX")
      (node (ref "U1") (pin "P0.06"))
      (node (ref "J2") (pin "3"))
    )
    (net (code "7") (name "RX")
      (node (ref "U1") (pin "P0.08"))
      (node (ref "J2") (pin "4"))
    )
    (net (code "8") (name "VREF")
      (node (ref "U1") (pin "P1.06"))
      (node (ref "J2") (pin "2"))
    )
  )
)
